---
import { Icon as AstroIcon } from "astro-icon/components";
import Icon from "./Icon.astro";
import type { Href, Tag } from "../projects";

interface Props {
    name: string;
    github: string;
    hrefs?: Href[];
    logo?: string;
    imgClass?: string;
    tags?: Tag[];
}

const {
    name,
    github,
    hrefs = [],
    logo,
    imgClass = "",
    tags = [],
} = Astro.props;
---

<div
    class="reveal glass flex flex-col rounded-xl p-5 transition-transform duration-500 ease-in-out hover:scale-[1.02]"
    data-tags={tags.map((t) => t.name.toLowerCase()).join(",")}
>
    {
        logo ? (
            <div class="mb-3 flex items-center gap-3">
                <div class="project-icon-frame">
                    <Icon
                        href={github}
                        img={`projects/${logo}`}
                        size="2.8em"
                        class:list={["drop-shadow-md opacity-90", imgClass]}
                        label={`${name} on GitHub`}
                    />
                </div>
                <h2 class="text-xl font-bold drop-shadow-md">{name}</h2>
            </div>
        ) : (
            <h2 class="mb-2 text-xl font-bold drop-shadow-md">{name}</h2>
        )
    }

    <div
        class="mb-4 line-clamp-3 text-sm leading-relaxed text-slate-200 drop-shadow-md"
    >
        <slot />
    </div>

    {
        tags.length > 0 && (
            <div class="mb-4 flex flex-wrap gap-1.5">
                {tags.map((tag) => (
                    <span class:list={["pill", tag.color]}>{tag.name}</span>
                ))}
            </div>
        )
    }

    <div
        class="mt-auto flex flex-wrap gap-2 pt-2 text-sm font-bold text-yellow-100"
    >
        <a
            class="icon-link"
            href={github}
            rel="noopener noreferrer"
            target="_blank"
            aria-label={`${name} on GitHub`}
        >
            <AstroIcon name="github" size="1.2em" class="text-yellow-100" />
        </a>
        {
            hrefs.map((link) => (
                <a
                    class="icon-link"
                    href={link.href}
                    rel="noopener noreferrer"
                    target="_blank"
                    title={link.hrefTitle}
                >
                    <AstroIcon name="link" size="1.2em" class="text-yellow-100" />
                    <span class="text-xs">{link.hrefTitle}</span>
                </a>
            ))
        }
    </div>
</div>

<style>
    @reference '../styles/global.css';

    a:hover,
    a:hover svg {
        @apply text-white;
    }

    .icon-link {
        @apply flex items-center gap-1 rounded-full border border-white/20 bg-white/5 px-2 py-1 transition-colors duration-200 hover:bg-white/15;
    }

    .project-icon-frame {
        @apply inline-flex h-16 w-16 shrink-0 items-center justify-center rounded-xl border border-white/20 bg-white/8 ring-1 ring-white/10;
    }
</style>
