---
interface Props {
    author: string;
    styles?: string;
}

const { author, styles = "" } = Astro.props;
---

<figure class={`flex flex-col gap-2 ${styles}`}>
    <blockquote>
        <p class="font-soft text-sm leading-relaxed text-white/50 italic">
            <slot />
        </p>
    </blockquote>
    <figcaption class="font-soft text-xs text-white/30">— {author}</figcaption>
</figure>
