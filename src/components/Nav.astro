---
import Icon from "./Icon.astro";

interface NavItem {
    name: string;
    url?: string;
}

interface Props {
    pages: NavItem[];
}

const { pages } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav
    id="main-nav"
    transition:persist
    class="nav-glass font-soft flex flex-wrap items-center gap-4 p-3 transition-all duration-500 md:gap-6 md:px-6 md:py-4"
>
    <Icon
        size="2em"
        img="home"
        href="/"
        target="_self"
        styles="w-6 h-6 md:w-7 md:h-7 text-slate-200"
        color="text-white"
        label="Home"
    />
    <div class="flex flex-wrap items-center gap-3 md:gap-5">
        {
            pages.map((page) => {
                const href = page.url || `/${page.name.toLowerCase()}`;
                const isActive =
                    currentPath === href || currentPath.startsWith(href + "/");

                return (
                    <a
                        class="nav-link text-sm tracking-wide md:text-base"
                        href={href}
                        data-text={page.name}
                        aria-current={isActive ? "page" : undefined}
                    >
                        {page.name}
                    </a>
                );
            })
        }
    </div>
</nav>

<style>
    /* Reserve bold width so layout doesn't shift when active */
    .nav-link {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.8);
        border-bottom: 2px solid rgba(255, 255, 255, 0.3);
        transition:
            font-weight 700ms ease,
            color 700ms ease,
            border-color 700ms ease;
    }

    .nav-link:hover {
        color: rgba(255, 255, 255, 1);
    }

    .nav-link[aria-current="page"] {
        font-weight: 700;
        color: rgba(255, 255, 255, 1);
        border-bottom-color: rgba(255, 255, 255, 1);
    }

    .nav-link::after {
        content: attr(data-text);
        font-weight: bold;
        height: 0;
        overflow: hidden;
        visibility: hidden;
        pointer-events: none;
    }

    .nav-glass {
        background: transparent;
        backdrop-filter: blur(0px);
        border-bottom: 0.5px solid rgba(255, 255, 255, 0.05);
    }

    .nav-glass.scrolled {
        background: rgba(255, 255, 255, 0.06);
        backdrop-filter: blur(32px) saturate(110%) url(#liquid-distortion);
        border-bottom: 0.5px solid rgba(255, 255, 255, 0.15);
        box-shadow:
            inset 0 0.5px 0 0 rgba(255, 255, 255, 0.2),
            0 1px 8px rgba(0, 0, 0, 0.04);
    }
</style>

<script>
    document.addEventListener("astro:page-load", () => {
        const nav = document.getElementById("main-nav");
        if (!nav) {
            return;
        }

        // Update active nav link on navigation
        const currentPath = window.location.pathname;
        const links = nav.querySelectorAll<HTMLAnchorElement>(".nav-link");
        links.forEach((link) => {
            const href = link.getAttribute("href");
            if (
                href &&
                (currentPath === href || currentPath.startsWith(href + "/"))
            ) {
                link.setAttribute("aria-current", "page");
            } else {
                link.removeAttribute("aria-current");
            }
        });

        const onScroll = () => {
            if (window.scrollY > 20) {
                nav.classList.add("scrolled");
            } else {
                nav.classList.remove("scrolled");
            }
        };

        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
    });
</script>
