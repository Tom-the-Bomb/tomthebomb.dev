---
import { fade } from "astro:transitions";

import MainHead from "../components/MainHead.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

import "../styles/global.css";

interface Props {
    title: string;
    description: string;
}

const { title, description } = Astro.props;
---

<html lang="en" transition:animate={fade({ duration: "1s" })}>
    <head>
        <MainHead title={title} description={description} />
    </head>
    <body
        class="flex min-h-dvh flex-col bg-gray-800 bg-linear-to-tr from-violet-500 to-orange-300 bg-fixed"
    >
        <header class="sticky top-0 z-50 flex-none">
            <Nav
                pages={[
                    { name: "About" },
                    { name: "Projects" },
                    { name: "Photography" },
                    {
                        name: "Aquaria",
                        url: "/photography/aquaria",
                    },
                ]}
            />
        </header>

        <main class="flex grow flex-col items-center justify-center">
            <slot />
        </main>

        <Footer />

        <svg class="fixed h-0 w-0" aria-hidden="true">
            <defs>
                <filter id="liquid-distortion">
                    <feTurbulence
                        type="fractalNoise"
                        baseFrequency="0.015 0.015"
                        numOctaves="3"
                        seed="2"
                        result="noise"></feTurbulence>
                    <feDisplacementMap
                        in="SourceGraphic"
                        in2="noise"
                        scale="3"
                        xChannelSelector="R"
                        yChannelSelector="G"></feDisplacementMap>
                </filter>
            </defs>
        </svg>
        <ul class="squares" aria-hidden="true">
            <li class="glass"></li>
            <li class="glass"></li>
            <li class="glass"></li>
            <li class="glass hidden! md:block"></li>
            <li class="glass"></li>
            <li class="glass"></li>
            <li class="glass"></li>
            <li class="glass hidden! md:block"></li>
            <li class="glass"></li>
            <li class="glass hidden! md:block"></li>
        </ul>
    </body>
</html>

<script>
    document.addEventListener("astro:page-load", () => {
        // Skip animations for elements already in viewport on load
        const animated = document.querySelectorAll<HTMLElement>(
            ".reveal, .fade-in-up, .fade-in",
        );
        animated.forEach((el) => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight && rect.bottom > 0) {
                el.style.animation = "none";
                el.style.transition = "none";
                el.style.opacity = "1";
                el.style.transform = "none";
                el.style.translate = "none";
                el.classList.add("visible");
                requestAnimationFrame(() => {
                    el.style.transition = "";
                });
            }
        });

        const reveals = document.querySelectorAll<HTMLElement>(".reveal");
        if (!reveals.length) return;

        const observer = new IntersectionObserver(
            (entries) => {
                entries.forEach((entry) => {
                    entry.target.classList.toggle(
                        "visible",
                        entry.isIntersecting,
                    );
                });
            },
            { threshold: 0.05 },
        );

        reveals.forEach((el) => observer.observe(el));
    });
</script>

<style>
    .squares {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 100dvh;
        overflow: hidden;
        z-index: -1000;
    }

    .squares li {
        position: absolute;
        display: block;
        list-style: none;
        width: 20px;
        height: 20px;
        animation: squares infinite linear;
        bottom: -150px;
        border-radius: 10%;
        will-change: transform, opacity;
    }

    .squares .glass {
        -webkit-backdrop-filter: none;
        backdrop-filter: none;
        background: rgba(255, 255, 255, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.35);
        overflow: visible;
    }

    .squares .glass::before,
    .squares .glass::after {
        display: none;
    }

    .squares li:nth-child(1) {
        left: 25%;
        width: 80px;
        height: 80px;
        animation-delay: 0s;
        animation-duration: 25s;
    }

    .squares li:nth-child(2) {
        left: 10%;
        width: 20px;
        height: 20px;
        animation-delay: 2s;
        animation-duration: 12s;
    }

    .squares li:nth-child(3) {
        left: 70%;
        width: 20px;
        height: 20px;
        animation-delay: 4s;
        animation-duration: 25s;
    }

    .squares li:nth-child(4) {
        left: 40%;
        width: 60px;
        height: 60px;
        animation-delay: 0s;
        animation-duration: 18s;
    }

    .squares li:nth-child(5) {
        left: 65%;
        width: 20px;
        height: 20px;
        animation-delay: 0s;
        animation-duration: 25s;
    }

    .squares li:nth-child(6) {
        left: 75%;
        width: 110px;
        height: 110px;
        animation-delay: 3s;
        animation-duration: 25s;
    }

    .squares li:nth-child(7) {
        left: 35%;
        width: 150px;
        height: 150px;
        animation-delay: 7s;
        animation-duration: 25s;
    }

    .squares li:nth-child(8) {
        left: 50%;
        width: 25px;
        height: 25px;
        animation-delay: 15s;
        animation-duration: 45s;
    }

    .squares li:nth-child(9) {
        left: 20%;
        width: 15px;
        height: 15px;
        animation-delay: 2s;
        animation-duration: 35s;
    }

    .squares li:nth-child(10) {
        left: 85%;
        width: 150px;
        height: 150px;
        animation-delay: 0s;
        animation-duration: 11s;
    }

    @keyframes squares {
        from {
            transform: translateY(0) rotate(0deg);
            opacity: 1;
            border-radius: 10%;
        }
        to {
            transform: translateY(-100dvh) rotate(720deg);
            opacity: 0.25;
            border-radius: 50%;
        }
    }
</style>
