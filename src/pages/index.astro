---
import { Image } from "astro:assets";
import { Icon as AstroIcon } from "astro-icon/components";

import { getCollection } from "astro:content";

import blobComfy from "../../public/blobcomfy.png";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAge } from "../utils";
import { projects } from "../projects";

const albums = await getCollection("albums");
---

<BaseLayout
  title="Tom the Bomb — Developer & Photographer"
  description="Personal website of Tom the Bomb — computer engineering student at the University of Waterloo, software developer, and photographer."
>
  <div
    class="flex grow flex-wrap items-center justify-center gap-14 px-6 md:gap-20"
  >
    <div class="order-1 flex flex-col gap-8 md:order-0">
      <div class="fade-in-up flex flex-col gap-2">
        <h2
          class="font-soft w-fit text-lg tracking-wide text-yellow-100 drop-shadow-lg md:text-2xl lg:text-3xl"
        >
          Hello, I am
        </h2>
        <h1
          class="typewriter w-fit font-mono text-[42px] leading-[1.1] font-extrabold md:text-6xl lg:text-7xl"
          aria-label="Tom the Bomb"
        >
          Tom the Bomb
        </h1>
        <p
          class="fade-in font-soft text-base tracking-wider text-white/70 [animation-delay:0.5s] md:text-lg"
        >
          Developer & Photographer
        </p>
      </div>
      <hr class="fade-in w-2/3 border-white/40 [animation-delay:0.3s]" />
      <div
        class="fade-in-up flex flex-col gap-3 [animation-delay:0.4s] md:flex-row"
      >
        {
          [
            { href: "/about", icon: "stack", label: "About" },
            {
              href: "/projects",
              icon: "lightbulb",
              label: "Projects",
            },
            {
              href: "/photography",
              icon: "camera",
              label: "Photography",
            },
            {
              href: "/photography/aquaria",
              icon: "fish",
              label: "Aquaria",
            },
          ].map(({ href, icon, label }) => (
            <a href={href} class="hero-btn glass">
              <AstroIcon name={icon} size="1.2em" />
              {label}
            </a>
          ))
        }
      </div>
      <div class="fade-in flex flex-wrap gap-3 [animation-delay:0.8s]">
        <div class="hero-stat">{projects.length} Projects</div>
        <div class="hero-stat">{albums.length} Albums</div>
        <div class="hero-stat">{getAge()} Years Old</div>
      </div>
    </div>
    <div class="fade-in order-0 flex [animation-delay:0.2s] md:order-1">
      <div
        class="float-bob glass glass-extras mt-14 flex h-[12em] w-[12em] items-center justify-center rounded-full p-7 md:mt-5 md:h-[14em] md:w-[14em]"
      >
        <Image
          src={blobComfy}
          alt="Blob Comfy"
          class="h-auto w-auto opacity-85 brightness-95 hue-rotate-30"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  @reference '../styles/global.css';

  .hero-btn {
    @apply flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold text-yellow-100 transition-all duration-500 hover:scale-[1.03] hover:text-white md:px-5 md:text-base;
  }

  .hero-stat {
    @apply rounded-full border border-white/30 bg-white/5 px-3 py-1 text-xs text-white/60;
  }

  .glass-extras {
    transition: transform 0.55s ease-in-out;
  }

  .glass-extras > :global(img) {
    transition: inherit;
  }

  .glass-extras:hover {
    transform: scale(1.1);
  }

  .glass-extras:hover > :global(img) {
    transform: scale(1.04);
  }
</style>
