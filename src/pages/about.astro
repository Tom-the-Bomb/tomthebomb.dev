---
import { Image } from "astro:assets";

import blobComfy from "../../public/blobcomfy.png";
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutSection from "../components/AboutSection.astro";
import Icon from "../components/Icon.astro";
import Tech from "../components/Tech.astro";
import TechCard from "../components/TechCard.astro";
import { getAge } from "../utils";
---

<BaseLayout
    title="About — Tom the Bomb"
    description="About Me — computer engineering student at Waterloo, experienced in Rust, Python, and web development, with a passion for photography and aquaria."
>
    <div
        id="about-page"
        class="mt-10 mb-32 flex w-full max-w-5xl flex-col items-center gap-16 px-6 lg:mt-24 lg:gap-20"
    >
        <div
            class="fade-in-up flex w-full max-w-3xl flex-col items-center gap-6 text-center md:flex-row md:items-start md:gap-10 md:text-left"
        >
            <div
                class="glass flex h-32 w-32 shrink-0 items-center justify-center rounded-full p-5 transition-transform duration-300 hover:scale-[1.05] md:h-36 md:w-36"
            >
                <Image
                    src={blobComfy}
                    alt="Blob Comfy"
                    class="h-auto w-auto opacity-80 brightness-95 hue-rotate-30"
                    loading="eager"
                    decoding="async"
                />
            </div>
            <div class="flex flex-col gap-3">
                <h1 class="text-5xl font-extrabold drop-shadow-lg md:text-6xl">
                    About Me
                </h1>
                <h2
                    class="text-2xl font-bold text-yellow-100 drop-shadow-lg md:text-3xl"
                >
                    Tom the Bomb
                </h2>
                <div
                    class="flex flex-wrap justify-center gap-2 md:justify-start"
                >
                    <div
                        class="glass flex items-center gap-2 rounded-full px-3 py-1.5"
                    >
                        <Icon
                            size="1.4em"
                            img="canada"
                            target="_self"
                            styles=""
                        />
                        <Icon
                            size="1.4em"
                            img="china"
                            target="_self"
                            styles=""
                        />
                    </div>
                    <div class="pill text-sm text-white/80">
                        {getAge()} years old
                    </div>
                    <div class="pill text-sm text-white/80">UWaterloo CE</div>
                </div>
            </div>
        </div>

        <div
            class="fade-in-up w-full max-w-3xl border-l-2 border-white/20 py-3 pl-5 text-base leading-relaxed drop-shadow-lg md:text-lg"
            style="animation-delay: 0.15s"
        >
            <p>
                Hi there! I'm a {getAge()} year old computer engineering student at
                the
                <strong>University of Waterloo</strong> who is passionate about software development,
                photography, image processing, mathematics, and improving my coding
                skills through leetcoding and building impactful applications that
                revolve around my interests.
            </p>
        </div>

        <AboutSection title="Development Tools" icon="stack" class="max-w-3xl">
            <div class="flex flex-col gap-10">
                <div
                    class="reveal section-group"
                >
                    <h3
                        class="section-heading"
                    >
                        Languages
                    </h3>
                    <p class="text-sm text-slate-300">
                        Primary languages for personal and academic projects
                    </p>
                    <div class="flex flex-wrap gap-2">
                        <TechCard
                            name="python"
                            label="Python"
                            color="text-python"
                        />
                        <TechCard name="rust" label="Rust" color="text-rust" />
                        <TechCard name="java" label="Java" color="text-java" />
                        <TechCard name="cpp" color="text-cpp" />
                    </div>
                </div>

                <div
                    class="reveal section-group"
                >
                    <h3
                        class="section-heading"
                    >
                        Web Development
                    </h3>
                    <p class="text-sm text-slate-300">
                        Frontend frameworks, bundlers, and styling tools
                    </p>
                    <div class="flex flex-wrap gap-2">
                        <TechCard
                            name="javascript"
                            label="JavaScript"
                            color="text-javascript"
                        />
                        <TechCard
                            name="typescript"
                            label="TypeScript"
                            color="text-typescript"
                        />
                        <TechCard name="html" label="HTML" color="text-html" />
                        <TechCard name="css" label="CSS" color="text-css" />
                        <TechCard
                            name="react"
                            label="React"
                            color="text-react"
                        />
                        <TechCard
                            name="nextjs"
                            label="Next.js"
                            color="text-nextjs"
                        />
                        <TechCard
                            name="astro"
                            label="Astro"
                            color="text-astro"
                        />
                        <TechCard
                            name="solidjs"
                            label="SolidJS"
                            color="text-solidjs"
                        />
                        <TechCard name="vite" label="Vite" color="text-vite" />
                        <TechCard
                            name="webassembly"
                            label="WebAssembly"
                            color="text-webassembly"
                        />
                    </div>
                </div>

                <div
                    class="reveal section-group"
                >
                    <h3
                        class="section-heading"
                    >
                        Styling
                    </h3>
                    <div class="flex flex-wrap gap-2">
                        <TechCard
                            name="tailwind"
                            label="Tailwind CSS"
                            color="text-tailwind"
                        />
                        <TechCard
                            name="bootstrap"
                            label="Bootstrap"
                            color="text-bootstrap"
                        />
                        <TechCard
                            name="shadcn"
                            label="shadcn/ui"
                            color="text-shadcn"
                        />
                    </div>
                </div>

                <div
                    class="reveal section-group"
                >
                    <h3
                        class="section-heading"
                    >
                        Backend
                    </h3>
                    <p class="text-sm text-slate-300">
                        Server frameworks and APIs
                    </p>
                    <div class="flex flex-wrap gap-2">
                        <TechCard
                            name="flask"
                            label="Flask & Quart"
                            color="text-flask"
                        />
                        <TechCard
                            name="fastapi"
                            label="FastAPI"
                            color="text-fastapi"
                        />
                        <TechCard name="rust" label="Axum" color="text-axum" />
                    </div>
                </div>

                <div
                    class="reveal section-group"
                >
                    <h3
                        class="section-heading"
                    >
                        Data Management
                    </h3>
                    <div class="flex flex-wrap gap-2">
                        <TechCard
                            name="mongo"
                            label="MongoDB"
                            color="text-mongo"
                        />
                        <TechCard
                            name="sqlite"
                            label="SQLite"
                            color="text-sqlite"
                        />
                        <TechCard
                            name="cloudflare"
                            label="Cloudflare D1 & R2"
                            color="text-cloudflare"
                        />
                    </div>
                </div>

                <div
                    class="reveal section-group"
                >
                    <h3
                        class="section-heading"
                    >
                        Libraries
                    </h3>
                    <p class="text-sm text-slate-300">
                        Image processing, numerical computing, and data
                        visualization
                    </p>
                    <div class="flex flex-wrap gap-2">
                        <TechCard
                            name="opencv"
                            label="OpenCV"
                            color="text-opencv"
                        />
                        <TechCard
                            name="numpy"
                            label="NumPy"
                            color="text-numpy"
                        />
                        <TechCard
                            name="sympy"
                            label="SymPy"
                            color="text-sympy"
                        />
                        <TechCard
                            name="matplotlib"
                            label="Matplotlib"
                            color="text-matplotlib"
                        />
                        <TechCard
                            name="python"
                            label="Pillow"
                            color="text-pillow"
                        />
                    </div>
                </div>

                <div
                    class="reveal flex items-center gap-3 font-sans text-sm text-white/50"
                >
                    <Icon size="1.5em" img="lightbulb" target="_self" />
                    <p>
                        This website was made with <span class="text-amber-100"
                            >Astro</span
                        >,
                        <span class="text-sky-200">TypeScript</span>, and <span
                            class="text-sky-200">Tailwind CSS</span
                        >
                    </p>
                </div>
            </div>
            <div class="reveal flex flex-wrap gap-3 pt-5">
                <a
                    href="/projects"
                    class="glass about-cta"
                >
                    View Projects
                </a>
                <a
                    href="https://github.com/Tom-the-Bomb"
                    rel="noopener noreferrer"
                    target="_blank"
                    class="glass group inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold text-white/70 transition-all duration-300 hover:scale-[1.03] hover:text-white"
                >
                    <Icon
                        size="1.2em"
                        img="github"
                        target="_self"
                        styles="text-white/50 group-hover:text-white"
                        color=""
                    />
                    GitHub
                </a>
            </div>
        </AboutSection>

        <hr class="reveal w-1/2 border-white/15" />

        <AboutSection title="Photography" icon="camera" class="max-w-3xl">
            <div class="flex flex-col gap-8">
                <div
                    class="reveal border-l-2 border-white/20 py-2 pl-5 leading-relaxed"
                >
                    <p>
                        <strong>Photography</strong> is a way of freezing moments in time, preserving
                        the beauty I come across, through visual storytelling. It
                        allows me to see the world from different perspectives and
                        appreciate the beauty in everyday life.
                    </p>
                </div>

                <div
                    class="reveal section-group"
                >
                    <h3
                        class="section-heading"
                    >
                        Gear
                    </h3>
                    <div class="grid gap-4 sm:grid-cols-2">
                        <div
                            class="glass gear-card"
                        >
                            <div class="flex items-center justify-between">
                                <div>
                                    <span
                                        class="font-nexa-black-italic text-xl font-black italic"
                                        >Nikon
                                    </span>
                                    <span class="text-xl">D5300</span>
                                </div>
                                <span class="pill text-xs text-slate-200"
                                    >2024&ndash;</span
                                >
                            </div>
                            <p class="mt-2 text-sm text-slate-300">
                                18&#8209;140mm f/3.5&#8209;5.6
                            </p>
                            <p class="text-sm text-slate-300">
                                70&#8209;300mm f/4.5&#8209;5.6
                            </p>
                        </div>
                        <div
                            class="glass gear-card"
                        >
                            <div class="flex items-center justify-between">
                                <div>
                                    <span
                                        class="font-nexa-black-italic text-xl font-black italic"
                                        >Nikon
                                    </span>
                                    <span class="text-xl">Z5II</span>
                                </div>
                                <span class="pill text-xs text-slate-200"
                                    >2025&ndash;</span
                                >
                            </div>
                            <p class="mt-2 text-sm text-slate-300">
                                24&#8209;200mm f/4&#8209;6.3
                            </p>
                        </div>
                    </div>
                    <p class="text-sm text-slate-300/70">
                        Previously: Canon RP, Canon Rebel T7s, iPhone 13 & 15
                        Pro
                    </p>
                </div>

                <div
                    class="reveal section-group"
                >
                    <h3
                        class="section-heading"
                    >
                        Genres
                    </h3>
                    <p class="text-sm text-slate-300">
                        Focusing on unique angles and interesting compositions
                    </p>
                    <div class="flex flex-wrap gap-2">
                        <span class="pill text-yellow-100">Architecture</span>
                        <span class="pill text-yellow-100">Street</span>
                        <span class="pill text-yellow-100"
                            >Landscapes & Cityscapes</span
                        >
                        <span class="pill text-yellow-100"
                            >Nature & Wildlife</span
                        >
                        <span class="pill text-yellow-100">Macro</span>
                    </div>
                </div>
            </div>
            <div class="reveal flex flex-wrap gap-3 pt-5">
                <a
                    href="/photography"
                    class="glass about-cta"
                >
                    View Photos
                </a>
                <a
                    href="https://www.instagram.com/tom_the_bomb_111/"
                    rel="noopener noreferrer"
                    target="_blank"
                    class="glass about-cta"
                >
                    <Tech
                        name="instagram"
                        styles="transition-colors duration-300">Instagram</Tech
                    >
                </a>
            </div>
        </AboutSection>

        <hr class="reveal w-1/2 border-white/15" />

        <AboutSection title="Aquaria" icon="fish" class="max-w-3xl">
            <div
                class="reveal flex max-w-3xl flex-col gap-4 border-l-2 border-white/20 py-2 pl-5 leading-relaxed"
            >
                <p>
                    For over five years, I've gained experience maintaining a
                    variety of aquatic life, including
                    <span class="text-blue-100">fish</span>, <span
                        class="text-green-100">plants</span
                    >,
                    <span class="text-yellow-100">invertebrates</span>
                    and <span class="text-red-100">corals</span>&mdash;both in
                    saltwater and freshwater setups—across multiple aquariums
                    and an outdoor pond.
                </p>
                <p>
                    Their uniqueness as pets, along with their natural beauty
                    and calmness they bring forth, has always deeply appealed to
                    me. While they may not be as interactive as dogs or cats,
                    having nearly self-sustaining ecosystems in your home,
                    complete with a range of creatures of all sizes, from
                    microscopic to large, resonates with me differently.
                </p>
            </div>
            <div class="reveal pt-3">
                <a
                    href="/photography/aquaria"
                    class="glass inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold text-yellow-100 transition-all duration-500 hover:scale-[1.03] hover:text-white"
                >
                    <Icon size="1.2em" img="camera" target="_self" styles="" />
                    View Aquaria Photos
                </a>
            </div>
        </AboutSection>
    </div>
    <style scoped>
        @reference '../styles/global.css';

        .section-group {
            @apply flex flex-col gap-3 border-l border-white/10 pl-4;
        }

        .section-heading {
            @apply w-fit border border-white/25 px-3 py-1 text-base font-bold;
        }

        .about-cta {
            @apply inline-flex items-center gap-2 rounded-full px-5 py-2 text-sm font-semibold text-white/70 transition-all duration-300 hover:scale-[1.03] hover:text-white;
        }

        .gear-card {
            @apply rounded-xl p-5 transition-transform duration-300 hover:scale-[1.02];
        }
    </style>
</BaseLayout>
